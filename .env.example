# General
ENV=development
DRY_RUN=true
LOG_LEVEL=INFO

# ATI.su API
ATI_CLIENT_ID=
ATI_CLIENT_SECRET=
ATI_ACCESS_TOKEN=
ATI_API_BASE_URL=https://api.ati.su
ATI_MODE=READ_ONLY
ATI_HTTP_TIMEOUT_SECONDS=20
ATI_HTTP_MAX_RETRIES=4

# Official ATI Messenger endpoints
ATI_MESSENGER_CREATE_CHAT_PATH=/messenger/1.1/chats/
ATI_MESSENGER_SUBSCRIPTIONS_PATH=/messenger/1.2/subscriptions/
ATI_MESSENGER_SEND_PATH=/messenger/1.2/chats/{chat_id}/messages
ATI_MESSENGER_HISTORY_PATH=/messenger/1.1/chats/{chat_id}/history/
ATI_MESSENGER_INBOX_PATH=/messenger/1.1/inbox/

# ATI geo and carrier search
ATI_GEO_AUTOCOMPLETE_PATH=/gw/gis-dict/v1/autocomplete/suggestions
ATI_TRUCKS_SEARCH_PATH=/v1.0/trucks/search/by-filter
ATI_ACTIVE_CARRIERS_SEARCH_PATH=/v2/dstats/active_firms/search
ATI_SEARCH_DEMO_MODE=true
ATI_DEFAULT_COUNTRY_ID=1

# Claude message generation (explicit opt-in)
ANTHROPIC_ENABLED=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_TIMEOUT_SECONDS=45
ANTHROPIC_MAX_TOKENS=500

# MAX Messenger
MAX_API_BASE=https://platform-api2.max.ru
MAX_ENABLED=true
MAX_BOT_TOKEN=
MAX_WEBHOOK_SECRET=
MAX_GROUP_CHAT_ID=
MAX_NAVIGATORS_CHAT_ID=
MAX_LEADS_CHAT_ID=
MAX_DRIVERS_CHAT_ID=
# Only this MAX user may approve ATI messages
MAX_OWNER_USER_ID=

# Gmail / Google Workspace
GMAIL_CREDENTIALS_PATH=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_ENABLED=true
GOOGLE_SHEETS_DRY_RUN=false

# Approvals / notifications
APPROVAL_EMAIL=
APPROVAL_CHAT_ID=

# Storage
DATABASE_URL=sqlite:///./ati_agent.db
