# General
ENV=development
DRY_RUN=true
LOG_LEVEL=INFO

# ATI.su API
ATI_CLIENT_ID=
ATI_CLIENT_SECRET=
ATI_ACCESS_TOKEN=
ATI_API_BASE_URL=https://api.ati.su
ATI_MODE=READ_ONLY

# ATI Messenger API contract
# Do not guess these paths. Fill them only from the official ATI documentation for the connected account.
ATI_MESSENGER_SEND_PATH=
ATI_MESSENGER_MESSAGES_PATH=
ATI_MESSENGER_CONVERSATION_FIELD=conversationId
ATI_MESSENGER_TEXT_FIELD=text
ATI_HTTP_TIMEOUT_SECONDS=20

# Claude message generation (explicit opt-in)
ANTHROPIC_ENABLED=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_TIMEOUT_SECONDS=45
ANTHROPIC_MAX_TOKENS=500

# MAX Messenger
MAX_BOT_TOKEN=
MAX_WEBHOOK_SECRET=
MAX_GROUP_CHAT_ID=

# Gmail / Google Workspace
GMAIL_CREDENTIALS_PATH=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEETS_ID=

# Approvals / notifications
APPROVAL_EMAIL=
APPROVAL_CHAT_ID=

# Storage
DATABASE_URL=sqlite:///./ati_agent.db
